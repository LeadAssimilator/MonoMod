<Project>

  <!-- The Arm64 helpers are fairly large and complex (at least for MacOS), so we want to build from scratch. -->
  <!-- Since they don't require custom tooling builds, this is fairly reasonable. -->

  <ItemGroup>
    <Arm64HelperOS Include="linux" Ext="so" Item="Arm64HelperLinux" TargetTriple="aarch64-linux-none"
        ExtraOpts="-shared -Wl,-x,--eh-frame-hdr,-z,now,-z,noexecstack,-z,norelro,--build-id=none -nodefaultlibs -nostdlib -s" />
    <Arm64HelperOS Include="macos" Ext="dylib" Item="Arm64HelperMacOS" TargetTriple="aarch64-macos"
        ExtraOpts="-shared -Wl,-x -mmacosx-version-min=11" />

    <Arm64HelperLinux Include="$(MSBuildThisFileDirectory)/exhelper_linux_macos_arm64.S" />
    <Arm64HelperMacOS Include="$(MSBuildThisFileDirectory)/exhelper_linux_macos_arm64.S" />
    <Arm64HelperMacOS Include="$(MSBuildThisFileDirectory)/helper_macos_arm64.cpp" ExtraOpts="-std=c++20 -lc++ -O3 -Wall" LinkerOpts="-lc++" />
  </ItemGroup>

  <PropertyGroup>
    <!--_MM_CompileLibs-->
  </PropertyGroup>

</Project>
